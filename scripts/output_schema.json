{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeliverablesLatest",
  "type": "object",
  "required": ["schema_version", "generated_at", "count", "deliverables"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "count": { "type": "integer", "minimum": 0 },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "host", "kind", "status", "created",
                     "url", "url_source", "url_status", "history"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "host": { "type": "string", "enum": ["vercel", "github-pages", "custom"] },
          "kind": { "type": "string", "enum": ["proposal", "campaign", "onboarding", "brief", "tool"] },
          "account": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "summary": { "type": "string" },
          "status": { "type": "string", "enum": ["live", "draft", "retired"] },
          "created": { "type": "string" },
          "url": { "type": ["string", "null"] },
          "url_source": { "type": "string", "enum": ["vercel-api", "formula", "hand-typed", "none"] },
          "url_status": { "type": "string", "enum": ["resolved", "unresolved"] },
          "url_error": { "type": "string" },
          "source_file": { "type": "string" },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "url_source", "status", "changed_at"],
              "additionalProperties": false,
              "properties": {
                "url": { "type": ["string", "null"] },
                "url_source": { "type": "string" },
                "status": { "type": "string" },
                "changed_at": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
