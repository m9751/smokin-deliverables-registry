# Required for `status: live` Vercel entries — Vercel API token (read-only scope).
# Used by scripts/compile.py to resolve the authoritative production URL per project.
# Without it, live Vercel entries fail the fail-closed URL gate (drafts still compile).
VERCEL_TOKEN=

# Optional — Vercel team/scope slug, if the projects live under a team rather than a personal account.
VERCEL_TEAM=

# Optional — override default log level (debug|info|warn|error).
LOG_LEVEL=info
